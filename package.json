{
  "name": "altius-chat-widget",
  "version": "1.0.0",
  "description": "Modular and maintainable chat widget for Altius",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:web": "node build.js --target=web",
    "build:mobile": "node build.js --target=mobile",
    "build:all": "node build.js --all",
    "unbuild": "node unbuild.js",
    "unbuild:web": "node unbuild.js altius-chat-widget.min.js",
    "unbuild:mobile": "node unbuild.js altius-chat-widget-mobile.min.js",
    "dev": "node dev-server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "watch": "npx chokidar-cli '**/*.js' '**/*.css' -c 'node build.js --all'"
  },
  "keywords": [
    "chat",
    "widget",
    "altius",
    "javascript",
    "modular"
  ],
  "author": "Altius Team",
  "license": "MIT",
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "eslint": "^8.0.0",
    "http-server": "^14.1.1",
    "jest": "^29.0.0",
    "prettier": "^2.8.8",
    "terser": "^5.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/altius/chat-widget.git"
  },
  "bugs": {
    "url": "https://github.com/altius/chat-widget/issues"
  },
  "homepage": "https://github.com/altius/chat-widget#readme"
}